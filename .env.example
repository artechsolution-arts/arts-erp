# ─────────────────────────────────────────────────────────────
#  Artech ERP — Configuration
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Site settings ────────────────────────────────────────────
SITE_NAME=artech.localhost
SITE_ADMIN_PASSWORD=admin

# ── Database ─────────────────────────────────────────────────
DB_NAME=artech_site
DB_USER=artech_site
DB_PASSWORD=artech123
DB_ROOT_PASSWORD=

# ── Server ───────────────────────────────────────────────────
PORT=8000

# ── Public URL (ngrok) ───────────────────────────────────────
# Sign up FREE at https://ngrok.com
# 1. Get authtoken → https://dashboard.ngrok.com/get-started/your-authtoken
# 2. Get 1 free static domain → https://dashboard.ngrok.com/cloud-edge/domains
#    It looks like: artech-yourname.ngrok-free.app
NGROK_AUTHTOKEN=
NGROK_STATIC_DOMAIN=
